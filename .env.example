# CurAItor Web App Configuration

# Storage backend: obsidian (default) or sqlite
# STORAGE_BACKEND=obsidian

# Obsidian vault path (auto-detected from Obsidian config if not set)
# Only used when STORAGE_BACKEND=obsidian
# VAULT_PATH=/path/to/your/obsidian/vault

# CurAItor plugin path (auto-detected if not set)
# Only used when STORAGE_BACKEND=obsidian
# PLUGIN_PATH=/path/to/claude-plugins/plugins/curaitor

# SQLite database path (only used when STORAGE_BACKEND=sqlite)
# SQLITE_PATH=./curaitor.db

# Server port (default: 3141)
# PORT=3141
