# Instapaper API credentials
# Get consumer key/secret at: https://www.instapaper.com/main/request_oauth_consumer_token
# Then do a one-time xAuth token exchange (see README.md)
INSTAPAPER_CONSUMER_KEY=
INSTAPAPER_CONSUMER_SECRET=
INSTAPAPER_ACCESS_TOKEN=
INSTAPAPER_ACCESS_SECRET=

# Instapaper RSS feed URL (fallback if API auth fails)
# Find at: Instapaper Settings → RSS Feed
INSTAPAPER_RSS_URL=

# Zotero API (optional, for saving references)
# Get at: https://www.zotero.org/settings/keys
ZOTERO_API_KEY=
ZOTERO_LIBRARY_ID=
ZOTERO_LIBRARY_TYPE=user
