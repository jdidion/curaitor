# Per-user curaitor settings (gitignored)
# Copy to config/user-settings.yaml and customize

# Default Slack channel for the "p" (post) command
# Can be a channel name or user ID (for DMs)
default_slack_channel: "#cool-ai-stuff"

# Custom bookmark command (optional)
# If set, "b" (bookmark) runs this instead of writing to Obsidian Bookmarks.md
# Available variables: $URL, $TITLE, $TAGS (JSON array)
# Example: save to Raindrop.io
# bookmark_command: "curl -s -X POST 'https://api.raindrop.io/rest/v1/raindrop' -H 'Authorization: Bearer $RAINDROP_TOKEN' -H 'Content-Type: application/json' -d '{\"link\": \"$URL\", \"title\": \"$TITLE\"}'"
